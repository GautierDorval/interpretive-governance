/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=()

/
  Cache-Control: no-store
  X-Inferens-Signal: ai-train=no, search=yes, ai-input=yes
  Link: <https://interpretive-governance.org/en/ai-policy>; rel="describedby"
  Link: <https://interpretive-governance.org/fr/politique-ia>; rel="describedby"

/en/*
  X-Inferens-Signal: ai-train=no, search=yes, ai-input=yes
  Link: <https://interpretive-governance.org/en/ai-policy>; rel="describedby"

/fr/*
  X-Inferens-Signal: ai-train=no, search=yes, ai-input=yes
  Link: <https://interpretive-governance.org/fr/politique-ia>; rel="describedby"

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/ai-governance.json
  X-Robots-Tag: noindex
/interpretation-policy.json
  X-Robots-Tag: noindex
/response-legitimacy.json
  X-Robots-Tag: noindex
/anti-plausibility.json
  X-Robots-Tag: noindex
/output-constraints.json
  X-Robots-Tag: noindex
/qlayer.json
  X-Robots-Tag: noindex
/ai-manifest.json
  X-Robots-Tag: noindex
/ai-policy.md
  X-Robots-Tag: noindex
/fr/politique-ia.md
  X-Robots-Tag: noindex
/doctrine-index.json
  X-Robots-Tag: noindex
/governance-fingerprint.json
  X-Robots-Tag: noindex
/entity-graph.jsonld
  X-Robots-Tag: noindex
/datasets.jsonld
  X-Robots-Tag: noindex
/well-known/*
  X-Robots-Tag: noindex
/.well-known/*
  X-Robots-Tag: noindex
