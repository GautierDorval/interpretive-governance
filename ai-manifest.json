      "interpretiveFunction": "canonical document inventory"
    },
    {
      "url": "https://interpretive-governance.org/ai-manifest.json",
      "tier": 2,
      "role": "routing_manifest",
      "interpretiveFunction": "discovery, reading order, question routing, and interpretive explanation"
    },
    {
      "url": "https://interpretive-governance.org/en/ai-policy",
      "tier": 2,
      "role": "human_policy_explainer",
      "interpretiveFunction": "explains how to use the governance files in English"
